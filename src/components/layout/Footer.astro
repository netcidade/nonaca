---
import { getDatabases, getEnvIds } from '../../lib/appwrite';
import { Query } from 'node-appwrite';

const env = import.meta.env;
const db = getDatabases(env);
const { DB_ID, COL_CONTENT, COL_PRODUCTS } = getEnvIds(env);

// Fetch pages config (specifically for layout/contato)
const pagesRes = await db.listDocuments(DB_ID, COL_CONTENT, [Query.equal('key', 'pages')]);
const content = pagesRes.documents[0] ? JSON.parse(pagesRes.documents[0].data) : {};

// Fetch products for the list
const productsRes = await db.listDocuments(DB_ID, COL_PRODUCTS, [Query.limit(100)]);
const products = productsRes.documents.map((d: any) => JSON.parse(d.data));

const contato = content.contato || {};
const footerLay = content.layout?.footer || {};
const logoFooter = footerLay.logo_url || "https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png";
const footerDesc = footerLay.desc || "Sistema de identificação com mais de 25 anos de experiência. Qualidade e inovação em Londrina/PR.";
---

<footer class="bg-nonaca-dark text-white">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <img
          src={logoFooter}
          alt="Nonaca"
          class="h-12 w-auto mb-4"
        />
        <p class="text-nonaca-sky text-sm leading-relaxed" set:html={footerDesc} />
      </div>

      <!-- Produtos -->
      <div>
        <h4
          class="font-heading font-semibold text-nonaca-gold mb-4 text-sm uppercase tracking-wider"
        >
          Produtos
        </h4>
        <ul class="space-y-2">
          {
            products.map((p) => (
              <li>
                <a
                  href={`/${p.slug}`}
                  class="text-nonaca-sky hover:text-white text-sm transition-colors"
                >
                  {p.navLabel || p.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h4
          class="font-heading font-semibold text-nonaca-gold mb-4 text-sm uppercase tracking-wider"
        >
          Empresa
        </h4>
        <ul class="space-y-2">
          <li>
            <a
              href="/quem-somos"
              class="text-nonaca-sky hover:text-white text-sm transition-colors"
              >Quem Somos</a
            >
          </li>
          <li>
            <a
              href="/#produtos"
              class="text-nonaca-sky hover:text-white text-sm transition-colors"
              >Produtos</a
            >
          </li>
          <li>
            <a
              href={`https://api.whatsapp.com/send?phone=${contato.whatsapp || '5543988179234'}`}
              class="text-nonaca-sky hover:text-white text-sm transition-colors"
              >Orçamento</a
            >
          </li>
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h4
          class="font-heading font-semibold text-nonaca-gold mb-4 text-sm uppercase tracking-wider"
        >
          Contato
        </h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2 text-nonaca-sky">
            <span class="mt-0.5">📍</span>
            <span set:html={contato.endereco || 'Rua Eduardo Benjamin Hosken, 200<br />CEP 86020-440 — Londrina/PR'} />
          </li>
          <li class="flex items-center gap-2 text-nonaca-sky">
            <span>📞</span>
            <div>
              {contato.telefone1 && (
                <a
                  href={`tel:${contato.telefone1.replace(/\D/g, '')}`}
                  class="hover:text-white transition-colors block"
                  >{contato.telefone1}</a
                >
              )}
              {contato.telefone2 && (
                <a
                  href={`tel:${contato.telefone2.replace(/\D/g, '')}`}
                  class="hover:text-white transition-colors block"
                  >{contato.telefone2}</a
                >
              )}
            </div>
          </li>
          {contato.whatsapp && (
            <li>
              <a
                href={`https://api.whatsapp.com/send?phone=${contato.whatsapp.replace(/\D/g, '')}`}
                target="_blank"
                class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors font-semibold"
              >
                <span>💬</span> WhatsApp
              </a>
            </li>
          )}
          {contato.email && (
            <li>
              <a
                href={`mailto:${contato.email}`}
                class="text-nonaca-sky hover:text-white transition-colors"
              >
                {contato.email}
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div
      class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-nonaca-sky"
    >
      <p>© {new Date().getFullYear()} Nonaca — Todos os direitos reservados.</p>
      <p>Desenvolvido com ❤️ por NetCidade</p>
    </div>
  </div>
</footer>
