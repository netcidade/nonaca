---
import products from '../../content/products.json';
---

<footer class="bg-nonaca-dark text-white">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <img src="https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png"
             alt="Nonaca" class="h-12 w-auto mb-4 brightness-200 invert" />
        <p class="text-nonaca-sky text-sm leading-relaxed">
          Sistema de identificação com mais de 25 anos de experiência. Qualidade e inovação em Londrina/PR.
        </p>
      </div>

      <!-- Produtos -->
      <div>
        <h4 class="font-heading font-semibold text-nonaca-gold mb-4 text-sm uppercase tracking-wider">Produtos</h4>
        <ul class="space-y-2">
          {products.map(p => (
            <li>
              <a href={`/${p.slug}`} class="text-nonaca-sky hover:text-white text-sm transition-colors">
                {p.navLabel}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-heading font-semibold text-nonaca-gold mb-4 text-sm uppercase tracking-wider">Empresa</h4>
        <ul class="space-y-2">
          <li><a href="/quem-somos" class="text-nonaca-sky hover:text-white text-sm transition-colors">Quem Somos</a></li>
          <li><a href="/#produtos" class="text-nonaca-sky hover:text-white text-sm transition-colors">Produtos</a></li>
          <li><a href="https://api.whatsapp.com/send?phone=5543988179234" class="text-nonaca-sky hover:text-white text-sm transition-colors">Orçamento</a></li>
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h4 class="font-heading font-semibold text-nonaca-gold mb-4 text-sm uppercase tracking-wider">Contato</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2 text-nonaca-sky">
            <span class="mt-0.5">📍</span>
            <span>Rua Eduardo Benjamin Hosken, 200<br>CEP 86020-440 — Londrina/PR</span>
          </li>
          <li class="flex items-center gap-2 text-nonaca-sky">
            <span>📞</span>
            <div>
              <a href="tel:4330261326" class="hover:text-white transition-colors block">(43) 3026-1326</a>
              <a href="tel:4333233692" class="hover:text-white transition-colors block">(43) 3323-3692</a>
            </div>
          </li>
          <li>
            <a href="https://api.whatsapp.com/send?phone=5543988179234" target="_blank"
               class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors font-semibold">
              <span>💬</span> WhatsApp
            </a>
          </li>
          <li>
            <a href="mailto:contato@nonaca.com.br" class="text-nonaca-sky hover:text-white transition-colors">
              contato@nonaca.com.br
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-nonaca-sky">
      <p>© {new Date().getFullYear()} Nonaca — Todos os direitos reservados.</p>
      <p>Desenvolvido com ❤️ em Londrina/PR</p>
    </div>
  </div>
</footer>
