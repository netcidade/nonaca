---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nonaca Admin — Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0f2d57;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      position: relative;
      overflow: hidden;
    }
    .particles { position: fixed; inset: 0; pointer-events: none; }
    .p { position: absolute; border-radius: 50%; animation: float var(--d,3s) ease-in-out var(--del,0s) infinite; }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-14px)} }

    .card {
      background: #fff;
      border-radius: 24px;
      padding: 2.5rem;
      width: 100%;
      max-width: 420px;
      position: relative;
      z-index: 10;
      animation: cardIn .4s ease-out both;
    }
    @keyframes cardIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    .logo { display: block; height: 48px; width: auto; margin: 0 auto 1.25rem; }
    h1 { font-family:'Poppins',sans-serif; font-size:1.4rem; font-weight:700; color:#1a4b8e; text-align:center; margin-bottom:.25rem; }
    .sub { font-size:.8rem; color:#6b7280; text-align:center; margin-bottom:2rem; }

    .field-label { font-size:.7rem; font-weight:700; color:#374151; text-transform:uppercase; letter-spacing:.06em; margin-bottom:.45rem; display:block; }

    .input-wrap { position:relative; margin-bottom:1.25rem; }
    .input-wrap input {
      width:100%; border:1.5px solid #e5e7eb; border-radius:12px;
      padding:.75rem 3rem .75rem 1rem;
      font-size:.9rem; outline:none; font-family:'Inter',sans-serif;
      transition:border-color .15s, box-shadow .15s;
      background:#fafafa;
    }
    .input-wrap input:focus {
      border-color:#1a4b8e;
      box-shadow:0 0 0 3px rgba(26,75,142,.1);
      background:#fff;
    }
    .input-wrap input.error-input { border-color:#ef4444; }

    /* Olhinho */
    .eye-btn {
      position:absolute; right:12px; top:50%; transform:translateY(-50%);
      background:none; border:none; cursor:pointer; padding:4px;
      color:#9ca3af; transition:color .15s; line-height:0;
    }
    .eye-btn:hover { color:#1a4b8e; }
    .eye-btn svg { width:18px; height:18px; }

    /* Força da senha */
    .strength-bar { height:3px; border-radius:2px; margin-top:5px; background:#e5e7eb; overflow:hidden; }
    .strength-fill { height:100%; border-radius:2px; transition:width .3s, background .3s; width:0; }

    /* Mensagem de erro */
    .error-msg {
      background:#fef2f2; border:1px solid #fca5a5; color:#dc2626;
      font-size:.8rem; padding:.6rem .9rem; border-radius:10px;
      margin-bottom:1rem; display:none; align-items:center; gap:6px;
    }
    .error-msg.show { display:flex; }

    /* Botão */
    .btn-login {
      width:100%; background:#1a4b8e; color:#fff;
      border:none; border-radius:12px; padding:.9rem;
      font-family:'Poppins',sans-serif; font-size:.95rem; font-weight:700;
      cursor:pointer; transition:background .15s, transform .1s;
      display:flex; align-items:center; justify-content:center; gap:8px;
    }
    .btn-login:hover:not(:disabled) { background:#2d6bc4; transform:translateY(-1px); }
    .btn-login:active { transform:translateY(0); }
    .btn-login:disabled { opacity:.7; cursor:not-allowed; }

    /* Spinner */
    .spinner {
      width:16px; height:16px; border:2px solid rgba(255,255,255,.3);
      border-top-color:#fff; border-radius:50%;
      animation:spin .6s linear infinite; display:none;
    }
    @keyframes spin { to{transform:rotate(360deg)} }

    /* Dica de senha */
    .hint { font-size:.75rem; color:#9ca3af; text-align:center; margin-top:1rem; }
    .hint code { background:#f3f4f6; padding:1px 5px; border-radius:4px; font-size:.75rem; color:#374151; }

    .back { display:block; text-align:center; margin-top:1rem; color:#6b7280; font-size:.8rem; text-decoration:none; }
    .back:hover { color:#1a4b8e; }
  </style>
</head>
<body>

  <!-- Partículas de fundo -->
  <div class="particles" id="pts"></div>

  <div class="card">
    <img class="logo" src="https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png" alt="Nonaca"/>
    <h1>Painel Admin</h1>
    <p class="sub">Entre com suas credenciais para continuar</p>

    <div class="error-msg" id="err">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span id="err-text">Senha incorreta. Tente novamente.</span>
    </div>

    <label class="field-label" for="pw">Senha de acesso</label>
    <div class="input-wrap">
      <input
        type="password"
        id="pw"
        placeholder="••••••••••"
        autocomplete="current-password"
        autofocus
      />
      <!-- Olhinho -->
      <button class="eye-btn" id="eye-btn" type="button" aria-label="Mostrar/ocultar senha" onclick="toggleEye()">
        <!-- Olho fechado (padrão — senha oculta) -->
        <svg id="eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
          <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
          <line x1="1" y1="1" x2="23" y2="23"/>
        </svg>
        <!-- Olho aberto (senha visível) -->
        <svg id="eye-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
    </div>

    <!-- Barra de força visual -->
    <div class="strength-bar"><div class="strength-fill" id="strength"></div></div>

    <br/>

    <button class="btn-login" id="btn-login" onclick="doLogin()">
      <div class="spinner" id="spinner"></div>
      <span id="btn-text">Entrar no painel</span>
    </button>

    <p class="hint">Senha padrão: <code>nonaca2025</code> — altere no arquivo <code>.env</code></p>
    <a href="/" class="back">← Voltar ao site</a>
  </div>

  <script>
    // Partículas
    const colors = ['#f5a623','#2d6bc4','#1a4b8e'];
    const c = document.getElementById('pts');
    for(let i=0;i<18;i++){
      const d=document.createElement('div'); d.className='p';
      const s=4+(i%5)*3;
      d.style.cssText=`width:${s}px;height:${s}px;background:${colors[i%3]};opacity:${0.1+(i%4)*0.06};left:${(i*17+5)%94}%;top:${(i*23+8)%88}%;--d:${2.5+(i%4)*.7}s;--del:${(i*.28)%2}s`;
      c.appendChild(d);
    }

    // Toggle olhinho
    function toggleEye() {
      const pw   = document.getElementById('pw');
      const off  = document.getElementById('eye-off');
      const on   = document.getElementById('eye-on');
      const show = pw.type === 'password';
      pw.type = show ? 'text' : 'password';
      off.style.display = show ? 'none' : '';
      on.style.display  = show ? ''     : 'none';
      pw.focus();
    }

    // Barra de força da senha (visual)
    document.getElementById('pw').addEventListener('input', function() {
      const v = this.value;
      const s = document.getElementById('strength');
      let pct = 0, color = '#ef4444';
      if(v.length >= 4)  { pct=25; color='#f97316'; }
      if(v.length >= 7)  { pct=55; color='#eab308'; }
      if(v.length >= 10) { pct=80; color='#22c55e'; }
      if(v.length >= 12 && /[A-Z]/.test(v) && /[0-9]/.test(v)) { pct=100; color='#16a34a'; }
      s.style.width=pct+'%'; s.style.background=color;
    });

    // Enter para logar
    document.getElementById('pw').addEventListener('keydown', e => {
      if(e.key==='Enter') doLogin();
    });

    async function doLogin() {
      const pw      = document.getElementById('pw');
      const btn     = document.getElementById('btn-login');
      const spinner = document.getElementById('spinner');
      const btnText = document.getElementById('btn-text');
      const err     = document.getElementById('err');
      const errText = document.getElementById('err-text');

      const password = pw.value.trim();
      if(!password) {
        pw.classList.add('error-input');
        errText.textContent = 'Por favor, digite a senha.';
        err.classList.add('show');
        pw.focus();
        return;
      }

      // Loading state
      btn.disabled = true;
      spinner.style.display = 'block';
      btnText.textContent = 'Verificando...';
      err.classList.remove('show');
      pw.classList.remove('error-input');

      try {
        const res = await fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });

        const data = await res.json();

        if(data.ok) {
          btnText.textContent = '✓ Entrando...';
          spinner.style.display = 'none';
          setTimeout(() => { window.location.href = '/admin'; }, 300);
        } else {
          throw new Error(data.error || 'Senha incorreta');
        }
      } catch(e) {
        pw.classList.add('error-input');
        errText.textContent = e.message || 'Erro ao conectar. Tente novamente.';
        err.classList.add('show');
        pw.value = '';
        pw.focus();
        btn.disabled = false;
        spinner.style.display = 'none';
        btnText.textContent = 'Entrar no painel';
      }
    }
  </script>
</body>
</html>

