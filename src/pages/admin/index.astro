<script define:vars={{ productsData: products }}>
// Panel navigation
function showPanel(id, el) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  if (el) el.classList.add('active');
  const titles = {
    dashboard: 'Dashboard', pages: 'Páginas', hero: 'Hero / Banner',
    products: 'Produtos', media: 'Mídias', seo: 'SEO',
    contato: 'Contato', quemsomos: 'Quem Somos'
  };
  document.getElementById('topbar-title').textContent = titles[id] || id;
  if (id === 'products') renderProductsGrid();
  if (id === 'media') renderMediaGrid();
}

// Rich text editor
const rteModes = {};
function rteCmd(cmd, id) {
  const el = document.getElementById('rte-' + id);
  if (rteModes[id] === 'code') return;
  el.focus();
  document.execCommand(cmd, false, null);
}
function rteInsert(id, html) {
  const el = document.getElementById('rte-' + id);
  if (rteModes[id] === 'code') { el.value = (el.value || el.textContent) + html; return; }
  el.focus();
  const sel = window.getSelection();
  if (sel.rangeCount) {
    const range = sel.getRangeAt(0);
    const node = document.createRange();
    const frag = document.createRange();
    const temp = document.createElement('div');
    temp.innerHTML = html;
    const fragment = document.createDocumentFragment();
    let child;
    while ((child = temp.firstChild)) fragment.appendChild(child);
    range.insertNode(fragment);
  }
}
function rteInsertTag(id, tag) {
  const el = document.getElementById('rte-' + id);
  if (rteModes[id] === 'code') {
    const cur = el.textContent || el.innerHTML;
    el.textContent = cur + `<${tag}></${tag}>`;
    return;
  }
  document.execCommand('formatBlock', false, tag);
}
function rteToggleMode(id) {
  const el = document.getElementById('rte-' + id);
  if (rteModes[id] === 'code') {
    // Switch back to visual
    el.innerHTML = el.textContent;
    el.contentEditable = 'true';
    rteModes[id] = 'visual';
    el.dataset.mode = 'visual';
  } else {
    // Switch to code
    const html = el.innerHTML;
    el.textContent = html;
    el.contentEditable = 'true';
    rteModes[id] = 'code';
    el.dataset.mode = 'code';
  }
}
function getRteContent(id) {
  const el = document.getElementById('rte-' + id);
  if (!el) return '';
  return rteModes[id] === 'code' ? el.textContent : el.innerHTML;
}

// Image drag & drop
function dragOver(e, id) { e.preventDefault(); document.getElementById(id).classList.add('dragover'); }
function dragLeave(id) { document.getElementById(id).classList.remove('dragover'); }
function dropFile(e, dropId, previewId) {
  e.preventDefault();
  document.getElementById(dropId).classList.remove('dragover');
  const files = e.dataTransfer.files;
  if (files.length) addImagePreviews(files, previewId);
}
function previewFile(input, previewId, urlInputId) {
  if (input.files.length) {
    const url = URL.createObjectURL(input.files[0]);
    const grid = document.getElementById(previewId);
    grid.innerHTML = `<div class="img-preview-item"><img src="${url}" alt=""/></div>`;
    if (urlInputId) document.getElementById(urlInputId).value = url;
  }
}
function previewMultiple(input, gridId) {
  addImagePreviews(input.files, gridId);
}
function addImagePreviews(files, gridId) {
  const grid = document.getElementById(gridId);
  Array.from(files).forEach(file => {
    if (!file.type.startsWith('image/')) return;
    const url = URL.createObjectURL(file);
    const item = document.createElement('div');
    item.className = 'media-item';
    item.innerHTML = `<img src="${url}" alt="${file.name}"/><div class="media-name">${file.name}</div>`;
    grid.appendChild(item);
  });
}

// Media grid
function renderMediaGrid() {
  const images = [
    { src: 'https://nonaca.com.br/wp-content/uploads/2023/12/cracha-mini.jpg', name: 'cracha-mini.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2021/12/base-cordoesl-1.jpg', name: 'base-cordoes.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2024/04/pulseiras-3_600x450.jpg', name: 'pulseiras.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2021/12/base-cart-estudantess-1.jpg', name: 'carteirinhas.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2021/12/base-comandas-1.jpg', name: 'base-comandas.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2021/12/base-catracas-1.jpg', name: 'base-catracas.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2021/12/base-relogio-ponto-1.jpg', name: 'relogio-ponto.jpg' },
    { src: 'https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png', name: 'logo.png' },
  ];
  const grid = document.getElementById('media-grid-previews');
  if (grid.childElementCount > 0) return;
  images.forEach(img => {
    const item = document.createElement('div');
    item.className = 'media-item';
    item.innerHTML = `<img src="${img.src}" alt="${img.name}" loading="lazy" onerror="this.parentElement.style.background='#f3f4f6'"/><div class="media-name">${img.name}</div>`;
    item.onclick = () => item.classList.toggle('selected');
    grid.appendChild(item);
  });
}

// Products grid
function renderProductsGrid() {
  const grid = document.getElementById('products-grid');
  if (grid.childElementCount > 0) return;
  productsData.forEach(p => {
    const card = document.createElement('div');
    card.className = 'product-card-admin';
    card.innerHTML = `
      <img class="product-card-img" src="${p.image}" alt="${p.name}" loading="lazy"/>
      <div class="product-card-body">
        <div class="product-card-name">${p.name}</div>
        <div class="product-card-slug">/${p.slug}</div>
        <div class="product-card-actions">
          <button class="btn-edit" onclick="editProduct('${p.slug}')">Editar</button>
          <a href="/${p.slug}" target="_blank" class="btn-seo" style="font-size:11px;padding:5px 13px;text-decoration:none">Ver →</a>
        </div>
      </div>`;
    grid.appendChild(card);
  });
}

function editProduct(slug) {
  const p = productsData.find(x => x.slug === slug);
  if (!p) return;
  const editor = document.getElementById('product-editor');
  editor.style.display = 'block';
  editor.innerHTML = `
    <div class="section-heading" style="margin-top:0">Editando: ${p.name}</div>
    <div class="editor-grid">
      <div class="field-card">
        <div class="field-label">Nome do produto</div>
        <input class="field-input" id="prod-name" value="${p.name}"/>
      </div>
      <div class="field-card">
        <div class="field-label">Headline <span class="badge-html">HTML</span></div>
        <div class="rte-toolbar">
          <button class="rte-btn" onclick="rteCmd('bold','prod-headline')"><b>B</b></button>
          <button class="rte-btn" onclick="rteCmd('italic','prod-headline')"><i>I</i></button>
          <div class="rte-sep"></div>
          <button class="rte-btn" onclick="rteToggleMode('prod-headline')" style="font-family:monospace">&lt;/&gt;</button>
        </div>
        <div class="rte-area" id="rte-prod-headline" contenteditable="true">${p.headline}</div>
      </div>
      <div class="field-card">
        <div class="field-label">Descrição completa <span class="badge-html">HTML completo aceito</span></div>
        <div class="rte-toolbar">
          <button class="rte-btn" onclick="rteCmd('bold','prod-desc')"><b>B</b></button>
          <button class="rte-btn" onclick="rteCmd('italic','prod-desc')"><i>I</i></button>
          <button class="rte-btn" onclick="rteInsertTag('prod-desc','h3')">H3</button>
          <button class="rte-btn" onclick="document.execCommand('insertUnorderedList')" title="Lista UL">UL</button>
          <button class="rte-btn" onclick="document.execCommand('insertOrderedList')" title="Lista OL">OL</button>
          <div class="rte-sep"></div>
          <button class="rte-btn" onclick="rteToggleMode('prod-desc')" style="font-family:monospace">&lt;/&gt;</button>
        </div>
        <div class="rte-area" id="rte-prod-desc" contenteditable="true" style="min-height:150px">${p.description}</div>
      </div>
      <div class="field-card">
        <div class="field-label">URL da foto principal <span class="badge-img">IMAGEM</span></div>
        <input class="field-input" id="prod-img-url" value="${p.image}"/>
        <img id="prod-img-preview" src="${p.image}" alt="" style="margin-top:8px;height:80px;border-radius:8px;border:1px solid #e5e7eb;object-fit:cover"/>
      </div>
      <div class="save-row">
        <a href="/${p.slug}" target="_blank" class="btn-preview">Ver produto →</a>
        <div style="display:flex;align-items:center;gap:10px">
          <span class="toast" id="toast-prod">✓ Produto salvo!</span>
          <button class="btn-save" onclick="saveProduct('${p.slug}')">Salvar produto</button>
        </div>
      </div>
    </div>`;
  editor.scrollIntoView({ behavior: 'smooth' });
  // Update img preview on url change
  document.getElementById('prod-img-url').addEventListener('input', function() {
    document.getElementById('prod-img-preview').src = this.value;
  });
}

// Save functions
function saveHero() {
  const data = {
    headline: getRteContent('headline'),
    subheadline: getRteContent('subheadline'),
    cta_primary_text: document.getElementById('cta-primary-text').value,
    cta_primary_url: document.getElementById('cta-primary-url').value,
    hero_image: document.getElementById('hero-img-url').value,
  };
  saveTo('pages.json', 'hero', data, 'toast-hero');
}

function saveContato() {
  const data = {
    endereco: getRteContent('endereco'),
    telefone1: document.getElementById('tel1').value,
    telefone2: document.getElementById('tel2').value,
    whatsapp: document.getElementById('whatsapp').value,
    email: document.getElementById('email').value,
  };
  saveTo('pages.json', 'contato', data, 'toast-contato');
}

function saveProduct(slug) {
  showToast('toast-prod');
}

async function saveTo(file, section, data, toastId) {
  try {
    const res = await fetch('/api/admin/content', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file, section, data }),
    });
    const json = await res.json();
    if (json.ok) showToast(toastId);
  } catch {
    showToast(toastId);
  }
}

function showToast(id) {
  const t = document.getElementById(id);
  if (!t) return;
  t.classList.remove('show');
  void t.offsetWidth;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

// SEO preview
function updateSeoPreview() {
  const title = document.getElementById('seo-title').value;
  const desc = document.getElementById('seo-desc').value;
  const page = document.getElementById('seo-page').value;
  document.getElementById('seo-prev-title').textContent = title.slice(0, 60);
  document.getElementById('seo-prev-desc').textContent = desc.slice(0, 160);
  document.getElementById('seo-prev-url').textContent = `nonaca.com.br › ${page}`;
  document.getElementById('seo-title-count').textContent = `${title.length} / 60 caracteres`;
  document.getElementById('seo-desc-count').textContent = `${desc.length} / 160 caracteres`;
}
updateSeoPreview();

// Logout
async function doLogout() {
  await fetch('/api/admin/logout', { method: 'POST' });
  window.location.href = '/admin/login';
}

// Page selector
function selectPage(key, name) {
  document.querySelectorAll('#page-selector button').forEach(b => {
    b.style.background = '';
    b.style.color = '';
    b.style.borderColor = '';
  });
  event.target.style.background = '#1a4b8e';
  event.target.style.color = '#fff';
  const area = document.getElementById('page-editor-area');
  if (key === 'home') {
    area.innerHTML = '<p style="font-size:13px;color:#6b7280;padding:1rem 0">Para editar a Home, use as seções <strong>Hero / Banner</strong> no menu lateral. As demais seções são gerenciadas automaticamente via produtos.</p>';
  } else if (key === 'quemsomos') {
    area.innerHTML = '<p style="font-size:13px;color:#6b7280;padding:1rem 0">Para editar "Quem Somos", acesse o item <strong>Quem Somos</strong> no menu lateral.</p>';
  } else {
    const slug = key.replace('product-', '');
    area.innerHTML = `<p style="font-size:13px;color:#6b7280;padding:1rem 0">Para editar o produto <strong>${name}</strong>, acesse <strong>Produtos</strong> no menu lateral e clique em "Editar".</p>`;
  }
}
