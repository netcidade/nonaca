// ─── MEDIA GERENCIADOR ───────────────────────────────
window.dragOver  = (e,id) => { e.preventDefault(); document.getElementById(id)?.classList.add('dragover'); }
window.dragLeave = (id)   => document.getElementById(id)?.classList.remove('dragover');

window.dropFile  = (e, dropId) => {
  e.preventDefault();
  document.getElementById(dropId)?.classList.remove('dragover');
  if (e.dataTransfer.files.length) window.uploadFiles(e.dataTransfer.files);
}

window.previewMultiple = (input) => {
  if (input.files.length) window.uploadFiles(input.files);
  input.value = ''; // reseta o input para permitir enviar a mesma imagem de novo se quiser
}

window.previewFile = (input, previewId, urlInputId) => {
  if (!input.files.length) return;
  const url = URL.createObjectURL(input.files[0]);
  document.getElementById(previewId).innerHTML = `<div class="img-preview-item"><img src="${url}" alt=""/></div>`;
  if (urlInputId) document.getElementById(urlInputId).value = url;
}

window.uploadFiles = async function(files) {
  const grid = document.getElementById('media-grid-previews');
  // Optional loading state text
  const originalHtml = grid.innerHTML;
  
  for (let file of Array.from(files)) {
    if (!file.type.startsWith('image/')) continue;
    const formData = new FormData();
    formData.append('file', file);
    try {
      const res = await fetch('/api/admin/media', { method: 'POST', body: formData });
      const r = await res.json();
      if(!r.ok) {
        alert('Erro ao enviar ' + file.name + ': ' + r.error);
      }
    } catch(e) { alert('Erro de conexão: ' + e.message); }
  }
  
  // Reload full grid after all uploads finish
  window.renderMediaGrid();
}

window.deleteMedia = async function(name) {
  if (!confirm(`Tem certeza que deseja excluir "${name}"? Essa ação apagará a foto do servidor.`)) return;
  try {
    const res = await fetch('/api/admin/media', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    const r = await res.json();
    if (r.ok) {
      window.renderMediaGrid();
    } else { alert('Erro ao excluir: ' + r.error); }
  } catch(e) { alert('Erro: ' + e.message); }
}

window.copyUrl = function(url, btn) {
  navigator.clipboard.writeText(url).then(() => {
    const old = btn.textContent;
    btn.textContent = 'Copiado!';
    btn.style.background = '#d1fae5';
    btn.style.color = '#065f46';
    setTimeout(() => {
      btn.textContent = old;
      btn.style.background = '';
      btn.style.color = '';
    }, 1500);
  });
}

window.renderMediaGrid = async function() {
  const grid = document.getElementById('media-grid-previews');
  if (!grid) return;
  
  grid.innerHTML = '<div style="color:var(--text-muted);font-size:12px;padding:1rem;">Carregando mídias...</div>';
  
  try {
    const res = await fetch('/api/admin/media');
    const r = await res.json();
    if(r.ok) {
      grid.innerHTML = '';
      if(r.media.length === 0) {
        grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem;color:#9ca3af;font-size:13px;background:#f8fafc;border-radius:12px;border:1px dashed var(--border)">Nenhuma imagem enviada ainda. Faça upload acima.</div>';
      }
      r.media.forEach(img => {
        const relativeUrl = img.url;
        const card = document.createElement('div');
        card.className = 'media-card';
        card.innerHTML = `
          <img class="media-card-img" src="${img.url}" loading="lazy" alt="${img.name}" />
          <div class="media-card-body">
            <div class="media-card-name" title="${img.name}">${img.name}</div>
            <div class="media-card-url-row">
              <input class="media-card-input" readonly value="${relativeUrl}" onclick="this.select()"/>
              <button class="media-card-btn-copy" onclick="copyUrl('${relativeUrl}', this)">Copiar</button>
            </div>
            <button class="media-card-btn-delete" onclick="deleteMedia('${img.name}')">Excluir</button>
          </div>
        `;
        grid.appendChild(card);
      });
    } else {
      grid.innerHTML = '<div style="color:red;font-size:12px">Erro: '+r.error+'</div>';
    }
  } catch(e) {
    grid.innerHTML = '<div style="color:red;font-size:12px">Falha ao tentar ler arquivos do servidor: '+e.message+'</div>';
  }
}

