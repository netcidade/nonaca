window.createProduct = async function() {
  const slug        = document.getElementById('new-slug').value.trim();
  const name        = document.getElementById('new-name').value.trim();
  const headline    = document.getElementById('new-headline').value.trim();
  const description = document.getElementById('new-description').value.trim();
  const image       = document.getElementById('new-image').value.trim();
  const featuresRaw = document.getElementById('new-features').value.trim();

  // Validações
  if (!slug)  { alert('Preencha o slug (URL) do produto.'); return; }
  if (!name)  { alert('Preencha o nome do produto.'); return; }
  if (productsData.find(p => p.slug === slug)) {
    alert(`Já existe um produto com o slug "${slug}". Escolha outro.`); return;
  }

  const features = featuresRaw ? featuresRaw.split(',').map(s => s.trim()).filter(Boolean) : [];

  const newProduct = {
    slug, name,
    headline:    headline    || `${name} personalizados.`,
    description: description || `<p>${name} com qualidade Nonaca.</p>`,
    image:       image       || 'https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png',
    features,
    navLabel: name,
  };

  const updated = [...productsData, newProduct];

  try {
    const res = await fetch('/api/admin/content', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: 'products.json', data: updated }),
    });
    const r = await res.json();
    if (r.ok) {
      productsData.push(newProduct);
      window.showSuccess(); 
      setTimeout(() => {
        window.closeModal();
        window.renderProductsGrid();
      }, 300);
    } else {
      alert('Erro ao criar produto: ' + (r.error || 'Tente novamente.'));
    }
  } catch(e) { alert('Erro de conexão: ' + e.message); }
}

window.deleteProduct = async function(slug, name) {
  const confirma = confirm(`Tem certeza que deseja excluir o produto "${name}"?\n\nEsta ação não pode ser desfeita.`);
  if (!confirma) return;

  const updated = productsData.filter(p => p.slug !== slug);

  try {
    const res = await fetch('/api/admin/content', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: 'products.json', data: updated }),
    });
    const r = await res.json();
    if (r.ok) {
      // Remove do array local
      const idx = productsData.findIndex(p => p.slug === slug);
      if (idx > -1) productsData.splice(idx, 1);
      // Fecha editor se estava aberto para este produto
      const editor = document.getElementById('product-editor');
      if (editor) editor.style.display = 'none';
      // Re-renderiza grid
      window.renderProductsGrid();
    } else {
      alert('Erro ao excluir: ' + (r.error || ''));
    }
  } catch(e) { alert('Erro: ' + e.message); }
}

