// ─── SHOW TOAST ──────────────────────────────────────
window.showToast = function(id) {
  const t = document.getElementById(id);
  if (!t) return;
  t.classList.remove('show'); void t.offsetWidth; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ─── LOGOUT ──────────────────────────────────────────
window.doLogout = async function() {
  await fetch('/api/admin/logout', { method:'POST' });
  window.location.href = '/admin/login';
}

// ─── PAGE SELECTOR ───────────────────────────────────
window.selectPage = function(key, name) {
  document.querySelectorAll('#page-selector button').forEach(b => {
    b.style.background = ''; b.style.color = '';
  });
  event.target.style.background = '#1a4b8e';
  event.target.style.color = '#fff';
  const area = document.getElementById('page-editor-area');
  if (key === 'home') area.innerHTML = '<p style="font-size:13px;color:#6b7280;padding:1rem 0">Use <strong>Hero / Banner</strong> no menu para editar a home.</p>';
  else if (key === 'quemsomos') area.innerHTML = '<p style="font-size:13px;color:#6b7280;padding:1rem 0">Use <strong>Quem Somos</strong> no menu.</p>';
  else area.innerHTML = `<p style="font-size:13px;color:#6b7280;padding:1rem 0">Use <strong>Produtos</strong> no menu e clique em "Editar" em <strong>${name}</strong>.</p>`;
}
</script>

