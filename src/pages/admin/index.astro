// ─── SEO LOGIC ───────────────────────────────────────
window.updateSeoPreview = function() {
  const page = document.getElementById('seo-page').value;
  let data = null;

  if (page === 'home' || page === 'quem-somos' || page === 'contato') {
    const key = page.replace('-', '');
    data = pagesData[key]?.seo;
  } else {
    data = productsData.find(p => p.slug === page)?.seo;
  }

  const title = data?.title || '';
  const desc  = data?.description || '';

  document.getElementById('seo-title').value = title;
  document.getElementById('seo-description').value = desc;
  
  window.updateSeoVisuals();
}

window.updateSeoVisuals = function() {
  const title = document.getElementById('seo-title').value;
  const desc  = document.getElementById('seo-description').value;
  const page  = document.getElementById('seo-page').value;

  // Counts
  document.getElementById('seo-title-count').textContent = `${title.length} / 60 caracteres`;
  document.getElementById('seo-desc-count').textContent = `${desc.length} / 160 caracteres`;

  // Visual Preview
  document.getElementById('preview-slug').textContent = page;
  document.getElementById('preview-title').textContent = title || 'Título da Página';
  document.getElementById('preview-desc').textContent = desc || 'Descrição da página no Google...';
}

window.saveSeo = async function() {
  const page = document.getElementById('seo-page').value;
  const title = document.getElementById('seo-title').value;
  const desc = document.getElementById('seo-description').value;
  const seoData = { title, description: desc };

  let payload = {};

  if (page === 'home' || page === 'quem-somos' || page === 'contato') {
    const key = page.replace('-', '');
    payload = {
      file: 'pages.json',
      section: key,
      data: { ...pagesData[key], seo: seoData }
    };
  } else {
    // Update products.json (needs to send full list or atomic product update if API supported it)
    // Current API content.ts overwrites 'section' or entire file.
    // Let's assume we need to update the specific product in the products array.
    const products = [...productsData];
    const idx = products.findIndex(p => p.slug === page);
    if (idx !== -1) {
      products[idx] = { ...products[idx], seo: seoData };
      payload = {
        file: 'products.json',
        data: products
      };
    }
  }

  try {
    const res = await fetch('/api/admin/content', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const r = await res.json();
    if (r.ok) {
      // Sync local data
      if (payload.file === 'pages.json') pagesData[payload.section].seo = seoData;
      else productsData.find(p => p.slug === page).seo = seoData;
      
      window.showSuccess();
    } else {
      alert('Erro ao salvar SEO: ' + (r.error || ''));
    }
  } catch(e) { alert('Erro: ' + e.message); }
}

