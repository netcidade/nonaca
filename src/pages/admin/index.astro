<!-- Quill JS — carregado no final para não bloquear render -->
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script define:vars={{ productsData: products, pagesData: content }}>

// ─── TOOLBAR COMPLETA ────────────────────────────────
const TOOLBAR_FULL = [
  [{ header: [1, 2, 3, false] }],
  ['bold', 'italic', 'underline', 'strike'],
  [{ color: [] }, { background: [] }],
  [{ list: 'ordered' }, { list: 'bullet' }],
  [{ align: [] }],
  ['link'],
  ['clean'],
];

const TOOLBAR_SIMPLE = [
  ['bold', 'italic', 'underline'],
  [{ color: [] }],
  ['link', 'clean'],
];

// Mapa de instâncias Quill: id → Quill instance
const quills = {};

// ─── CRIA EDITOR QUILL ───────────────────────────────
function createQuill(id, toolbar, initialHtml) {
  const el = document.getElementById('ql-' + id);
  if (!el || quills[id]) return;
  const q = new Quill(el, {
    theme: 'snow',
    modules: { toolbar },
    placeholder: 'Digite aqui...',
  });
  if (initialHtml) q.clipboard.dangerouslyPasteHTML(initialHtml);
  quills[id] = q;
  // Sincroniza textarea de código ao digitar
  q.on('text-change', () => {
    const ta = document.getElementById('html-' + id);
    if (ta && !ta.classList.contains('visible')) return;
    if (ta) ta.value = q.getSemanticHTML();
  });
  return q;
}

// ─── TOGGLE MODO HTML ────────────────────────────────
window.toggleHtmlMode = function(id) {
  const ta  = document.getElementById('html-' + id);
  const btn = document.getElementById('btn-html-' + id);
  const q   = quills[id];
  if (!ta || !q) return;

  if (ta.classList.contains('visible')) {
    // Volta pro WYSIWYG — aplica o HTML editado
    q.clipboard.dangerouslyPasteHTML(ta.value);
    ta.classList.remove('visible');
    btn.classList.remove('active');
    btn.textContent = '</> Ver HTML';
  } else {
    // Mostra HTML
    ta.value = q.getSemanticHTML();
    ta.classList.add('visible');
    btn.classList.add('active');
    btn.textContent = '↩ Voltar WYSIWYG';
    ta.style.minHeight = '120px';
    // Se editar no textarea, sincroniza ao sair
    ta.oninput = () => {}; // live não — só ao voltar
  }
}

// ─── PEGA HTML DO QUILL ──────────────────────────────
window.getQuillHtml = function(id) {
  const ta = document.getElementById('html-' + id);
  // Se estiver no modo código, usa o textarea
  if (ta && ta.classList.contains('visible')) return ta.value;
  return quills[id] ? quills[id].getSemanticHTML() : '';
}

// ─── INICIALIZA QUILLS ESTÁTICOS ─────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const h = pagesData.home || {};
  createQuill('headline',    TOOLBAR_SIMPLE, h.hero?.headline    || 'Sua <strong>identidade</strong><br>começa aqui.');
  createQuill('subheadline', TOOLBAR_SIMPLE, h.hero?.subheadline || 'Crachás, cordões e pulseiras. <strong>Mais de 25 anos</strong> em Londrina/PR.');
  createQuill('endereco',    TOOLBAR_SIMPLE, pagesData.contato?.endereco || 'Rua Eduardo Benjamin Hosken, 200<br>CEP: 86020-440 — Londrina/PR');
  createQuill('qs-headline', TOOLBAR_SIMPLE, pagesData.quemsomos?.hero_headline || '25 anos identificando <strong>pessoas e marcas</strong>.');
  createQuill('qs-about',    TOOLBAR_FULL,   pagesData.quemsomos?.about_text || '<p>A <strong>Nonaca</strong> nasceu em 1999.</p>');
});

// ─── PAINEL NAVIGATION ───────────────────────────────
window.showPanel = function(id, el) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const target = document.getElementById('panel-' + id);
  if (target) target.classList.add('active');
  if (el) el.classList.add('active');
  const titles = {
    dashboard:'Dashboard', pages:'Páginas', hero:'Hero / Banner',
    products:'Produtos', media:'Mídias', seo:'SEO',
    contato:'Contato', quemsomos:'Quem Somos',
  };
  document.getElementById('topbar-title').textContent = titles[id] || id;
  if (id === 'products') window.renderProductsGrid();
  if (id === 'media')    window.renderMediaGrid();
}

// ─── IMAGE DRAG & DROP ───────────────────────────────
window.dragOver  = (e,id) => { e.preventDefault(); document.getElementById(id)?.classList.add('dragover'); }
window.dragLeave = (id)   => document.getElementById(id)?.classList.remove('dragover');
window.dropFile  = (e, dropId, previewId) => {
  e.preventDefault();
  document.getElementById(dropId)?.classList.remove('dragover');
  if (e.dataTransfer.files.length) addImagePreviews(e.dataTransfer.files, previewId);
}
window.previewFile = (input, previewId, urlInputId) => {
  if (!input.files.length) return;
  const url = URL.createObjectURL(input.files[0]);
  document.getElementById(previewId).innerHTML = `<div class="img-preview-item"><img src="${url}" alt=""/></div>`;
  if (urlInputId) document.getElementById(urlInputId).value = url;
}
window.previewMultiple = (input, gridId) => addImagePreviews(input.files, gridId);

function addImagePreviews(files, gridId) {
  const grid = document.getElementById(gridId);
  Array.from(files).forEach(file => {
    if (!file.type.startsWith('image/')) return;
    const url = URL.createObjectURL(file);
    const item = document.createElement('div');
    item.className = 'media-item';
    item.innerHTML = `<img src="${url}" alt="${file.name}"/><div class="media-name">${file.name}</div>`;
    grid.appendChild(item);
  });
}

// ─── MEDIA GRID ──────────────────────────────────────
window.renderMediaGrid = function() {
  const images = [
    { src:'https://nonaca.com.br/wp-content/uploads/2023/12/cracha-mini.jpg', name:'cracha-mini.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2021/12/base-cordoesl-1.jpg', name:'base-cordoes.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2024/04/pulseiras-3_600x450.jpg', name:'pulseiras.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2021/12/base-cart-estudantess-1.jpg', name:'carteirinhas.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2021/12/base-comandas-1.jpg', name:'comandas.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2021/12/base-catracas-1.jpg', name:'catracas.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2021/12/base-relogio-ponto-1.jpg', name:'relogio.jpg' },
    { src:'https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png', name:'logo.png' },
  ];
  const grid = document.getElementById('media-grid-previews');
  if (grid.childElementCount > 0) return;
  images.forEach(img => {
    const item = document.createElement('div'); item.className = 'media-item';
    item.innerHTML = `<img src="${img.src}" alt="${img.name}" loading="lazy" onerror="this.parentElement.style.background='#f3f4f6'"/><div class="media-name">${img.name}</div>`;
    item.onclick = () => item.classList.toggle('selected');
    grid.appendChild(item);
  });
}

// ─── PRODUCTS GRID ───────────────────────────────────
window.renderProductsGrid = function() {
  const grid = document.getElementById('products-grid');
  grid.innerHTML = ''; // sempre re-renderiza para refletir mudanças
  productsData.forEach(p => {
    const card = document.createElement('div'); card.className = 'product-card-admin';
    card.innerHTML = `
      <img class="product-card-img" src="${p.image}" alt="${p.name}" loading="lazy" onerror="this.src='https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png'"/>
      <div class="product-card-body">
        <div class="product-card-name">${p.name}</div>
        <div class="product-card-slug">/${p.slug}</div>
        <div class="product-card-actions">
          <button class="btn-edit" onclick="editProduct('${p.slug}')">Editar</button>
          <a href="/${p.slug}" target="_blank" class="btn-seo" style="font-size:11px;padding:5px 10px;text-decoration:none">Ver →</a>
          <button onclick="deleteProduct('${p.slug}','${p.name}')"
            style="font-size:11px;padding:5px 10px;border-radius:7px;border:1px solid #fca5a5;background:#fef2f2;color:#dc2626;cursor:pointer;font-family:'Inter',sans-serif;transition:all .15s"
            onmouseover="this.style.background='#fee2e2'" onmouseout="this.style.background='#fef2f2'">
            🗑
          </button>
        </div>
      </div>`;
    grid.appendChild(card);
  });
}

// ─── MODAL NOVO PRODUTO ──────────────────────────────
window.openNewProduct = function() {
  const overlay = document.getElementById('modal-overlay');
  overlay.style.display = 'flex';
  // Limpa campos
  ['new-slug','new-name','new-headline','new-description','new-image','new-features'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('new-img-preview').style.display = 'none';
  document.getElementById('new-slug').focus();
}

window.closeModal = function() {
  document.getElementById('modal-overlay').style.display = 'none';
}

window.updateNewImgPreview = function(url) {
  const img = document.getElementById('new-img-preview');
  if (url && url.startsWith('http')) {
    img.src = url; img.style.display = 'block';
  } else {
    img.style.display = 'none';
  }
}

window.createProduct = async function() {
  const slug        = document.getElementById('new-slug').value.trim();
  const name        = document.getElementById('new-name').value.trim();
  const headline    = document.getElementById('new-headline').value.trim();
  const description = document.getElementById('new-description').value.trim();
  const image       = document.getElementById('new-image').value.trim();
  const featuresRaw = document.getElementById('new-features').value.trim();

  // Validações
  if (!slug)  { alert('Preencha o slug (URL) do produto.'); return; }
  if (!name)  { alert('Preencha o nome do produto.'); return; }
  if (productsData.find(p => p.slug === slug)) {
    alert(`Já existe um produto com o slug "${slug}". Escolha outro.`); return;
  }

  const features = featuresRaw ? featuresRaw.split(',').map(s => s.trim()).filter(Boolean) : [];

  const newProduct = {
    slug, name,
    headline:    headline    || `${name} personalizados.`,
    description: description || `<p>${name} com qualidade Nonaca.</p>`,
    image:       image       || 'https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png',
    features,
    navLabel: name,
  };

  const updated = [...productsData, newProduct];

  try {
    const res = await fetch('/api/admin/content', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: 'products.json', data: updated }),
    });
    const r = await res.json();
    if (r.ok) {
      productsData.push(newProduct);
      window.showToast('toast-new');
      setTimeout(() => {
        window.closeModal();
        window.renderProductsGrid();
        // Abre o editor do produto recém-criado
        window.editProduct(slug);
      }, 1200);
    } else {
      alert('Erro ao criar produto: ' + (r.error || 'Tente novamente.'));
    }
  } catch(e) { alert('Erro de conexão: ' + e.message); }
}

window.deleteProduct = async function(slug, name) {
  const confirma = confirm(`Tem certeza que deseja excluir o produto "${name}"?\n\nEsta ação não pode ser desfeita.`);
  if (!confirma) return;

  const updated = productsData.filter(p => p.slug !== slug);

  try {
    const res = await fetch('/api/admin/content', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: 'products.json', data: updated }),
    });
    const r = await res.json();
    if (r.ok) {
      // Remove do array local
      const idx = productsData.findIndex(p => p.slug === slug);
      if (idx > -1) productsData.splice(idx, 1);
      // Fecha editor se estava aberto para este produto
      const editor = document.getElementById('product-editor');
      if (editor) editor.style.display = 'none';
      // Re-renderiza grid
      window.renderProductsGrid();
    } else {
      alert('Erro ao excluir: ' + (r.error || ''));
    }
  } catch(e) { alert('Erro: ' + e.message); }
}

// Fecha modal ao clicar fora
document.getElementById('modal-overlay')?.addEventListener('click', function(e) {
  if (e.target === this) window.closeModal();
});
// Fecha com ESC
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') window.closeModal();
});
window.editProduct = function(slug) {
  const p = productsData.find(x => x.slug === slug);
  if (!p) return;
  const editor = document.getElementById('product-editor');
  editor.style.display = 'block';
  editor.innerHTML = `
    <div class="section-heading" style="margin-top:0">Editando: ${p.name}</div>
    <div class="editor-grid">
      <div class="field-card">
        <div class="field-label">Nome do produto</div>
        <input class="field-input" id="prod-name" value="${p.name}"/>
      </div>

      <div class="field-card">
        <div class="field-label">Headline <span class="badge-html">WYSIWYG</span></div>
        <div class="ql-wrapper" id="ql-wrap-prod-headline"><div id="ql-prod-headline"></div></div>
        <div class="html-toggle">
          <button onclick="toggleHtmlMode('prod-headline')" id="btn-html-prod-headline">&lt;/&gt; Ver HTML</button>
        </div>
        <textarea class="html-source" id="html-prod-headline"></textarea>
      </div>

      <div class="field-card">
        <div class="field-label">Descrição completa <span class="badge-html">WYSIWYG</span></div>
        <div class="ql-wrapper ql-tall" id="ql-wrap-prod-desc"><div id="ql-prod-desc"></div></div>
        <div class="html-toggle">
          <button onclick="toggleHtmlMode('prod-desc')" id="btn-html-prod-desc">&lt;/&gt; Ver HTML</button>
        </div>
        <textarea class="html-source" id="html-prod-desc"></textarea>
      </div>

      <div class="field-card">
        <div class="field-label">URL da foto principal <span class="badge-img">IMAGEM</span></div>
        <input class="field-input" id="prod-img-url" value="${p.image}" oninput="document.getElementById('prod-img-preview').src=this.value"/>
        <img id="prod-img-preview" src="${p.image}" alt="" style="margin-top:8px;height:80px;border-radius:8px;border:1px solid #e5e7eb;object-fit:cover"/>
      </div>

      <div class="save-row">
        <a href="/${p.slug}" target="_blank" class="btn-preview">Ver produto →</a>
        <div style="display:flex;align-items:center;gap:10px">
          <span class="toast" id="toast-prod">✓ Produto salvo!</span>
          <button class="btn-save" onclick="saveProduct('${p.slug}')">Salvar produto</button>
        </div>
      </div>
    </div>`;

  editor.scrollIntoView({ behavior: 'smooth' });

  // Inicia Quills dinâmicos — aguarda DOM
  setTimeout(() => {
    // Limpa instâncias anteriores
    delete quills['prod-headline'];
    delete quills['prod-desc'];
    createQuill('prod-headline', TOOLBAR_SIMPLE, p.headline    || '');
    createQuill('prod-desc',     TOOLBAR_FULL,   p.description || '');
  }, 60);
}

// ─── SAVE PRODUCT ────────────────────────────────────
window.saveProduct = async function(slug) {
  const name     = document.getElementById('prod-name')?.value ?? '';
  const headline = window.getQuillHtml('prod-headline');
  const desc     = window.getQuillHtml('prod-desc');
  const image    = document.getElementById('prod-img-url')?.value ?? '';

  const updated = productsData.map(p =>
    p.slug !== slug ? p : { ...p, name, headline, description: desc, image }
  );
  try {
    const res = await fetch('/api/admin/content', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ file:'products.json', data: updated }),
    });
    const r = await res.json();
    if (r.ok) {
      const idx = productsData.findIndex(p => p.slug === slug);
      if (idx > -1) Object.assign(productsData[idx], { name, headline, description: desc, image });
      window.showToast('toast-prod');
    } else { alert('Erro ao salvar: ' + (r.error || '')); }
  } catch(e) { alert('Erro: ' + e.message); }
}

// ─── SAVE HERO ───────────────────────────────────────
window.saveHero = async function() {
  const data = {
    headline:         window.getQuillHtml('headline'),
    subheadline:      window.getQuillHtml('subheadline'),
    cta_primary_text: document.getElementById('cta-primary-text').value,
    cta_primary_url:  document.getElementById('cta-primary-url').value,
    hero_image:       document.getElementById('hero-img-url').value,
  };
  try {
    const res = await fetch('/api/admin/content?file=pages.json');
    const cur = await res.json();
    cur.home = cur.home ?? {}; cur.home.hero = { ...(cur.home.hero || {}), ...data };
    const save = await fetch('/api/admin/content', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ file:'pages.json', data: cur }),
    });
    const r = await save.json();
    if (r.ok) window.showToast('toast-hero');
    else alert('Erro: ' + (r.error || ''));
  } catch(e) { alert('Erro: ' + e.message); }
}

