---
export const prerender = false;
import products from '../../content/products.json';
import content from '../../content/pages.json';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nonaca Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <!-- Quill WYSIWYG -->
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet"/>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --sidebar-bg: #0f2d57;
      --sidebar-hover: #1a4b8e;
      --sidebar-active: #1a4b8e;
      --accent: #f5a623;
      --blue: #1a4b8e;
      --blue-light: #2d6bc4;
      --text: #1f2937;
      --text-muted: #6b7280;
      --bg: #f4f5f7;
      --white: #ffffff;
      --border: #e5e7eb;
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); display: flex; min-height: 100vh; }

    /* Sidebar */
    .sidebar {
      width: 240px; background: var(--sidebar-bg); min-height: 100vh;
      display: flex; flex-direction: column; flex-shrink: 0;
      position: sticky; top: 0; height: 100vh; overflow-y: auto;
    }
    .sidebar-logo { padding: 1.25rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar-logo img { height: 36px; width: auto; filter: brightness(0) invert(1); }
    .sidebar-logo span { display: block; font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 3px; font-family: 'Inter', sans-serif; }
    .nav-section-label {
      font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.35);
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 1.25rem 1rem 0.4rem;
    }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 14px; cursor: pointer; transition: background 0.15s;
      border-left: 3px solid transparent; text-decoration: none;
      color: rgba(255,255,255,0.65); font-size: 13px;
    }
    .nav-item:hover { background: rgba(255,255,255,0.07); color: #fff; }
    .nav-item.active { background: var(--sidebar-active); border-left-color: var(--accent); color: #fff; }
    .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .sidebar-footer {
      margin-top: auto; padding: 1rem; border-top: 1px solid rgba(255,255,255,0.08);
    }
    .user-info { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .user-avatar { width: 30px; height: 30px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: #412402; flex-shrink: 0; }
    .user-name { font-size: 11px; color: rgba(255,255,255,0.8); font-weight: 500; }
    .user-role { font-size: 10px; color: rgba(255,255,255,0.4); }
    .logout-btn { width: 100%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); border-radius: 8px; padding: 7px; font-size: 11px; cursor: pointer; transition: all 0.15s; font-family: 'Inter', sans-serif; }
    .logout-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }

    /* Main */
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .topbar {
      background: var(--white); border-bottom: 1px solid var(--border);
      padding: 0 1.5rem; height: 56px; display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0; position: sticky; top: 0; z-index: 10;
    }
    .topbar-title { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 600; color: var(--blue); }
    .topbar-right { display: flex; align-items: center; gap: 10px; }
    .view-site-btn {
      display: flex; align-items: center; gap: 6px;
      background: var(--blue); color: #fff; border: none; border-radius: 8px;
      padding: 6px 14px; font-size: 12px; font-weight: 500; cursor: pointer;
      text-decoration: none; transition: background 0.15s;
      font-family: 'Inter', sans-serif;
    }
    .view-site-btn:hover { background: var(--blue-light); }
    .content { flex: 1; overflow-y: auto; padding: 1.5rem; }

    /* Panels */
    .panel { display: none; }
    .panel.active { display: block; }

    /* Dashboard cards */
    .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .metric-card { background: var(--white); border-radius: 14px; padding: 1.1rem 1.25rem; border: 1px solid var(--border); }
    .metric-value { font-family: 'Poppins', sans-serif; font-size: 28px; font-weight: 700; color: var(--blue); }
    .metric-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    .metric-icon { font-size: 20px; margin-bottom: 6px; }

    /* Section heading */
    .section-heading { font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 1rem; padding-bottom: 8px; border-bottom: 1px solid var(--border); }

    /* Table/list */
    .pages-list { display: flex; flex-direction: column; gap: 8px; }
    .page-row { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; transition: border-color 0.15s; }
    .page-row:hover { border-color: var(--blue-light); }
    .page-info { display: flex; align-items: center; gap: 10px; }
    .page-icon { width: 32px; height: 32px; background: #EBF2FB; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .page-icon svg { width: 14px; height: 14px; stroke: var(--blue); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .page-name { font-size: 13px; font-weight: 500; color: var(--text); }
    .page-slug { font-size: 11px; color: var(--text-muted); font-family: monospace; }
    .page-actions { display: flex; gap: 6px; }
    .btn-edit { background: #EBF2FB; color: var(--blue); border: none; border-radius: 7px; padding: 5px 13px; font-size: 11px; font-weight: 500; cursor: pointer; transition: background 0.15s; font-family: 'Inter', sans-serif; }
    .btn-edit:hover { background: #d0e4f7; }
    .btn-seo { background: var(--bg); color: var(--text-muted); border: 1px solid var(--border); border-radius: 7px; padding: 5px 13px; font-size: 11px; cursor: pointer; transition: all 0.15s; font-family: 'Inter', sans-serif; }
    .btn-seo:hover { border-color: var(--blue); color: var(--blue); }

    /* Editor grid e campos */
    .editor-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    .field-card { background: var(--white); border: 1px solid var(--border); border-radius: 14px; padding: 1rem 1.25rem; }
    .field-label { font-size: 10px; font-weight: 600; color: var(--text-muted); letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
    .badge-html { font-size: 9px; background: #ECFDF5; color: #065f46; border: 1px solid #6ee7b7; padding: 1px 6px; border-radius: 10px; font-weight: 600; }
    .badge-img  { font-size: 9px; background: #FFF7ED; color: #92400e; border: 1px solid #fed7aa; padding: 1px 6px; border-radius: 10px; font-weight: 600; }
    .field-input { width: 100%; border: 1px solid var(--border); border-radius: 8px; padding: 8px 12px; font-size: 13px; font-family: 'Inter', sans-serif; outline: none; background: #fafafa; transition: border-color .15s; }
    .field-input:focus { border-color: var(--blue); background: #fff; box-shadow: 0 0 0 3px rgba(26,75,142,.08); }
    .field-select { width: 100%; border: 1px solid var(--border); border-radius: 8px; padding: 8px 12px; font-size: 13px; font-family: 'Inter', sans-serif; outline: none; background: #fafafa; height: 36px; }
    .field-textarea { width: 100%; border: 1px solid var(--border); border-radius: 8px; padding: 8px 12px; font-size: 13px; font-family: 'Inter', sans-serif; outline: none; background: #fafafa; resize: vertical; min-height: 80px; line-height: 1.6; transition: border-color .15s; }
    .field-textarea:focus { border-color: var(--blue); background: #fff; box-shadow: 0 0 0 3px rgba(26,75,142,.08); }

    /* Quill customizado — tema Nonaca */
    .ql-wrapper { border-radius: 10px; overflow: hidden; border: 1.5px solid var(--border); transition: border-color .15s; }
    .ql-wrapper:focus-within { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(26,75,142,.08); }
    .ql-wrapper .ql-toolbar { background: #f8fafc; border: none; border-bottom: 1px solid var(--border); padding: 6px 10px; font-family: 'Inter', sans-serif; }
    .ql-wrapper .ql-container { border: none; font-family: 'Inter', sans-serif; font-size: 13px; }
    .ql-wrapper .ql-editor { min-height: 100px; padding: 10px 14px; line-height: 1.7; }
    .ql-wrapper .ql-editor.ql-blank::before { font-style: normal; color: #9ca3af; font-size: 13px; }
    .ql-wrapper.ql-tall .ql-editor { min-height: 180px; }
    /* Toolbar buttons cor Nonaca */
    .ql-wrapper .ql-toolbar button:hover,
    .ql-wrapper .ql-toolbar button.ql-active { color: var(--blue) !important; }
    .ql-wrapper .ql-toolbar button:hover .ql-stroke,
    .ql-wrapper .ql-toolbar button.ql-active .ql-stroke { stroke: var(--blue) !important; }
    .ql-wrapper .ql-toolbar button:hover .ql-fill,
    .ql-wrapper .ql-toolbar button.ql-active .ql-fill { fill: var(--blue) !important; }
    .ql-wrapper .ql-toolbar .ql-picker-label:hover { color: var(--blue); }
    /* Toggle modo HTML */
    .html-toggle { display:flex; align-items:center; gap:6px; margin-top:6px; }
    .html-toggle button {
      font-size:10px; padding:3px 10px; border-radius:6px; cursor:pointer;
      border:1px solid var(--border); background:#f8fafc; color:var(--text-muted);
      font-family:'Inter',sans-serif; transition:all .15s;
    }
    .html-toggle button.active { background:var(--blue); color:#fff; border-color:var(--blue); }
    .html-source {
      display:none; width:100%; min-height:100px; padding:10px 14px;
      font-family:monospace; font-size:12px; line-height:1.65; resize:vertical;
      border:1.5px solid var(--blue); border-radius:10px; background:#f8fafc;
      outline:none; color:var(--text);
    }
    .html-source.visible { display:block; }

    /* Image upload */
    .img-drop { border: 2px dashed var(--border); border-radius: 10px; padding: 1.25rem; text-align: center; cursor: pointer; transition: all .15s; background: #fafafa; }
    .img-drop:hover, .img-drop.dragover { border-color: var(--blue); background: #EBF2FB; }
    .img-drop-icon { font-size: 24px; margin-bottom: 6px; }
    .img-drop-text { font-size: 12px; color: var(--text-muted); }
    .img-drop-sub { font-size: 10px; color: #9ca3af; margin-top: 3px; }
    .img-preview-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .img-preview-item { position: relative; }
    .img-preview-item img { width: 72px; height: 54px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border); }

    /* Save row */
    .save-row { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; flex-wrap: wrap; gap: 8px; }
    .btn-save { background: var(--blue); color: #fff; border: none; border-radius: 10px; padding: 9px 22px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all .15s; font-family: 'Poppins', sans-serif; }
    .btn-save:hover { background: var(--blue-light); transform: translateY(-1px); }
    .btn-preview { background: transparent; color: var(--text-muted); border: 1px solid var(--border); border-radius: 10px; padding: 8px 16px; font-size: 13px; cursor: pointer; transition: all .15s; font-family: 'Inter', sans-serif; text-decoration: none; display: inline-block; }
    .btn-preview:hover { border-color: var(--blue); color: var(--blue); }
    .toast { display: none; font-size: 11px; color: #065f46; background: #ECFDF5; border: 1px solid #6ee7b7; padding: 6px 14px; border-radius: 8px; }
    .toast.show { display: inline-block; animation: fadeInOut 2.5s forwards; }
    @keyframes fadeInOut { 0%{opacity:0} 10%{opacity:1} 80%{opacity:1} 100%{opacity:0} }

    /* Products */
    .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
    .product-card-admin { background: var(--white); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; transition: border-color .15s, box-shadow .15s; cursor: pointer; }
    .product-card-admin:hover { border-color: var(--blue-light); box-shadow: 0 4px 12px rgba(26,75,142,.08); }
    .product-card-img { width: 100%; height: 120px; object-fit: cover; }
    .product-card-body { padding: 10px 12px; }
    .product-card-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
    .product-card-slug { font-size: 10px; color: var(--text-muted); font-family: monospace; }
    .product-card-actions { display: flex; gap: 6px; margin-top: 8px; }

    /* SEO */
    .seo-preview { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 12px 16px; margin-top: 10px; }
    .seo-url { font-size: 11px; color: #1a7f37; font-family: monospace; margin-bottom: 4px; }
    .seo-title-prev { font-size: 16px; color: #1558d6; font-weight: 400; margin-bottom: 3px; }
    .seo-desc-prev { font-size: 12px; color: #4d5156; line-height: 1.5; }
    .seo-label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 5px; }

    /* Media grid */
    .media-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 8px; margin-top: 12px; }
    .media-item { position: relative; aspect-ratio: 4/3; border-radius: 8px; overflow: hidden; border: 2px solid transparent; cursor: pointer; transition: border-color 0.15s; }
    .media-item:hover { border-color: var(--blue); }
    .media-item.selected { border-color: var(--accent); }
    .media-item img { width: 100%; height: 100%; object-fit: cover; }
    .media-name { font-size: 9px; color: var(--text-muted); text-align: center; margin-top: 3px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

    /* Responsive */
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .sidebar.open { display: flex; position: fixed; z-index: 100; }
    }
  </style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <img src="https://nonaca.com.br/wp-content/uploads/2021/11/logo2-forte.png" alt="Nonaca"/>
    <span>Painel de Administração</span>
  </div>

  <div class="nav-section-label">Conteúdo</div>
  <a href="javascript:void(0)" class="nav-item active" onclick="showPanel('dashboard',this);return false">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
    Dashboard
  </a>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('pages',this)">
    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    Páginas
  </a>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('hero',this)">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
    Hero / Banner
  </a>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('products',this)">
    <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    Produtos
  </a>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('media',this)">
    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    Mídias
  </a>

  <div class="nav-section-label">Configurações</div>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('seo',this)">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    SEO
  </a>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('contato',this)">
    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.35 2 2 0 0 1 3.57 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.1A16 16 0 0 0 16 16.09l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    Contato
  </a>
  <a href="javascript:void(0)" class="nav-item" onclick="showPanel('quemsomos',this)">
    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    Quem Somos
  </a>

  <div class="sidebar-footer">
    <div class="user-info">
      <div class="user-avatar">N</div>
      <div>
        <div class="user-name">Administrador</div>
        <div class="user-role">nonaca.com.br</div>
      </div>
    </div>
    <button class="logout-btn" onclick="doLogout()">Sair da conta</button>
  </div>
</aside>

<!-- Main -->
<div class="main">
  <div class="topbar">
    <span class="topbar-title" id="topbar-title">Dashboard</span>
    <div class="topbar-right">
      <a href="/" target="_blank" class="view-site-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Ver site
      </a>
    </div>
  </div>

  <div class="content">

    <!-- DASHBOARD -->
    <div class="panel active" id="panel-dashboard">
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-icon">📄</div>
          <div class="metric-value">10</div>
          <div class="metric-label">Páginas ativas</div>
        </div>
        <div class="metric-card">
          <div class="metric-icon">🏷️</div>
          <div class="metric-value">8</div>
          <div class="metric-label">Produtos</div>
        </div>
        <div class="metric-card">
          <div class="metric-icon">⭐</div>
          <div class="metric-value">183</div>
          <div class="metric-label">Avaliações Google</div>
        </div>
        <div class="metric-card">
          <div class="metric-icon">📍</div>
          <div class="metric-value">LDA</div>
          <div class="metric-label">Londrina/PR</div>
        </div>
      </div>

      <div class="section-heading">Acesso rápido — Páginas</div>
      <div class="pages-list">
        {[
          {name:'Home', slug:'/'},
          {name:'Quem Somos', slug:'/quem-somos'},
          ...products.map(p => ({name: p.name, slug: `/${p.slug}`}))
        ].map(p => (
          <div class="page-row">
            <div class="page-info">
              <div class="page-icon">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div>
              <div>
                <div class="page-name">{p.name}</div>
                <div class="page-slug">{p.slug}</div>
              </div>
            </div>
            <div class="page-actions">
              <button class="btn-edit" onclick="showPanel('pages', null)">Editar</button>
              <button class="btn-seo" onclick="showPanel('seo', null)">SEO</button>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- PAGES -->
    <div class="panel" id="panel-pages">
      <div class="section-heading">Páginas do site</div>
      <p style="font-size:13px;color:#6b7280;margin-bottom:1rem">Clique em uma página para editar o conteúdo. Selecione abaixo:</p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1.5rem" id="page-selector">
        {[
          {name:'Home', key:'home'},
          {name:'Quem Somos', key:'quemsomos'},
        ].map(p => (
          <button class="btn-edit" style="font-size:12px;padding:6px 16px" onclick={`selectPage('${p.key}','${p.name}')`}>
            {p.name}
          </button>
        ))}
        {products.map(p => (
          <button class="btn-seo" style="font-size:12px;padding:6px 16px" onclick={`selectPage('product-${p.slug}','${p.name}')`}>
            {p.name}
          </button>
        ))}
      </div>
      <div id="page-editor-area" style="font-size:13px;color:#9ca3af;text-align:center;padding:2rem">
        ↑ Selecione uma página acima para editar
      </div>
    </div>

    <!-- HERO -->
    <div class="panel" id="panel-hero">
      <div class="section-heading">Hero / Banner principal</div>
      <div class="editor-grid">

        <div class="field-card">
          <div class="field-label">Headline <span class="badge-html">WYSIWYG</span></div>
          <div class="ql-wrapper" id="ql-wrap-headline">
            <div id="ql-headline"></div>
          </div>
