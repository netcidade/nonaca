}

// ─── SAVE PRODUCT ────────────────────────────────────
window.saveProduct = async function(slug) {
  const name     = document.getElementById('prod-name')?.value ?? '';
  const headline = window.getQuillHtml('prod-headline');
  const desc     = window.getQuillHtml('prod-desc');
  const image    = document.getElementById('prod-img-url')?.value ?? '';

  const updated = productsData.map(p =>
    p.slug !== slug ? p : { ...p, name, headline, description: desc, image }
  );
  try {
    const res = await fetch('/api/admin/content', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ file:'products.json', data: updated }),
    });
    const r = await res.json();
    if (r.ok) {
      const idx = productsData.findIndex(p => p.slug === slug);
      if (idx > -1) Object.assign(productsData[idx], { name, headline, description: desc, image });
      window.showSuccess();
    } else { alert('Erro ao salvar: ' + (r.error || '')); }
  } catch(e) { alert('Erro: ' + e.message); }
}

