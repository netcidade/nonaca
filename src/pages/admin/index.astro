<!-- Quill JS — carregado no final para não bloquear render -->
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script define:vars={{ productsData: products, pagesData: content }}>

// ─── TOOLBAR COMPLETA ────────────────────────────────
const TOOLBAR_FULL = [
  [{ header: [1, 2, 3, false] }],
  ['bold', 'italic', 'underline', 'strike'],
  [{ color: [] }, { background: [] }],
  [{ list: 'ordered' }, { list: 'bullet' }],
  [{ align: [] }],
  ['link'],
  ['clean'],
];

const TOOLBAR_SIMPLE = [
  ['bold', 'italic', 'underline'],
  [{ color: [] }],
  ['link', 'clean'],
];

// Mapa de instâncias Quill: id → Quill instance
const quills = {};

// ─── CRIA EDITOR QUILL ───────────────────────────────
function createQuill(id, toolbar, initialHtml) {
  const el = document.getElementById('ql-' + id);
  if (!el || quills[id]) return;
  const q = new Quill(el, {
    theme: 'snow',
    modules: { toolbar },
    placeholder: 'Digite aqui...',
  });
  if (initialHtml) q.clipboard.dangerouslyPasteHTML(initialHtml);
  quills[id] = q;
  // Sincroniza textarea de código ao digitar
  q.on('text-change', () => {
    const ta = document.getElementById('html-' + id);
    if (ta && !ta.classList.contains('visible')) return;
    if (ta) ta.value = q.getSemanticHTML();
  });
  return q;
}

// ─── TOGGLE MODO HTML ────────────────────────────────
window.toggleHtmlMode = function(id) {
  const ta  = document.getElementById('html-' + id);
  const btn = document.getElementById('btn-html-' + id);
  const q   = quills[id];
  if (!ta || !q) return;

  if (ta.classList.contains('visible')) {
    // Volta pro WYSIWYG — aplica o HTML editado
    q.clipboard.dangerouslyPasteHTML(ta.value);
    ta.classList.remove('visible');
    btn.classList.remove('active');
    btn.textContent = '</> Ver HTML';
  } else {
    // Mostra HTML
    ta.value = q.getSemanticHTML();
    ta.classList.add('visible');
    btn.classList.add('active');
    btn.textContent = '↩ Voltar WYSIWYG';
    ta.style.minHeight = '120px';
    // Se editar no textarea, sincroniza ao sair
    ta.oninput = () => {}; // live não — só ao voltar
  }
}

// ─── PEGA HTML DO QUILL ──────────────────────────────
window.getQuillHtml = function(id) {
  const ta = document.getElementById('html-' + id);
  // Se estiver no modo código, usa o textarea
  if (ta && ta.classList.contains('visible')) return ta.value;
  return quills[id] ? quills[id].getSemanticHTML() : '';
}

// ─── INICIALIZA QUILLS ESTÁTICOS ─────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const h = pagesData.home || {};
  createQuill('headline',    TOOLBAR_SIMPLE, h.hero?.headline    || 'Sua <strong>identidade</strong><br>começa aqui.');
  createQuill('subheadline', TOOLBAR_SIMPLE, h.hero?.subheadline || 'Crachás, cordões e pulseiras. <strong>Mais de 25 anos</strong> em Londrina/PR.');
  createQuill('endereco',    TOOLBAR_SIMPLE, pagesData.contato?.endereco || 'Rua Eduardo Benjamin Hosken, 200<br>CEP: 86020-440 — Londrina/PR');
  createQuill('qs-headline', TOOLBAR_SIMPLE, pagesData.quemsomos?.hero_headline || '25 anos identificando <strong>pessoas e marcas</strong>.');
  createQuill('qs-about',    TOOLBAR_FULL,   pagesData.quemsomos?.about_text || '<p>A <strong>Nonaca</strong> nasceu em 1999.</p>');

  // Restaura o estado da UI após HMR
  setTimeout(() => {
    const act = sessionStorage.getItem('admin_active_panel');
    if (act && document.getElementById('panel-' + act) && !['hero', 'seo', 'contato', 'quemsomos'].includes(act)) {
      window.showPanel(act);
    }
    const modalType = sessionStorage.getItem('admin_modal_type');
    const modalId = sessionStorage.getItem('admin_modal_id');
    
    if (modalType === 'edit_product' && modalId) {
       window.showPanel('products');
       setTimeout(() => window.editProduct(modalId), 50);
    } else if (modalType === 'edit_page' && modalId) {
       window.selectPage(modalId);
    }

    if (sessionStorage.getItem('admin_show_success') === 'true') {
       sessionStorage.removeItem('admin_show_success');
       window.showSuccess();
    }
  }, 100);
});

// ─── PAINEL NAVIGATION ───────────────────────────────
window.showPanel = function(id, el) {
  const titles = {
    dashboard:'Dashboard', pages:'Páginas', hero:'Hero / Banner',
    products:'Produtos', media:'Mídias', seo:'SEO',
    contato:'Contato', quemsomos:'Quem Somos',
  };

  // Se for uma seção de edição, abre no modal
  const isEdit = ['hero', 'seo', 'contato', 'quemsomos'].includes(id);
  
  if (isEdit) {
    window.openEditModal(id, titles[id]);
    return;
  }

  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  
  const target = document.getElementById('panel-' + id);
  if (target) target.classList.add('active');
  if (el) el.classList.add('active');
  
  document.getElementById('topbar-title').textContent = titles[id] || id;
  if (id === 'products') window.renderProductsGrid();
  if (id === 'media')    window.renderMediaGrid();

  sessionStorage.setItem('admin_active_panel', id);
}

// ─── MODAL EDIT HELPERS ──────────────────────────────
window.openEditModal = function(id, title) {
  const modal = document.getElementById('modal-edit');
  const body = document.getElementById('modal-edit-body');
  const titleEl = document.getElementById('modal-edit-title');
  
  titleEl.textContent = title;
  
  // Move o painel para dentro do modal
  const panel = document.getElementById('panel-' + id);
  if (panel) {
    body.innerHTML = '';
    body.appendChild(panel);
    panel.classList.add('active');
    modal.classList.add('active');
    
    // Ajustes específicos por seção
    if (id === 'seo') window.updateSeoPreview();
  }
  
  sessionStorage.setItem('admin_modal_type', 'edit_page');
  sessionStorage.setItem('admin_modal_id', id);
}

window.closeEditModal = function() {
  const modal = document.getElementById('modal-edit');
  const body = document.getElementById('modal-edit-body');
  
  // Devolve o painel para o content original apenas se for um ".panel" fixo
  const panel = body.firstElementChild;
  if (panel && panel.classList.contains('panel')) {
    document.querySelector('.content').appendChild(panel);
    panel.classList.remove('active');
  } else {
    // Se for conteúdo dinâmico (ex: editor de produto), apenas limpa
    body.innerHTML = '';
  }
  
  modal.classList.remove('active');
  sessionStorage.removeItem('admin_modal_type');
  sessionStorage.removeItem('admin_modal_id');
}

